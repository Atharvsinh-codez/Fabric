# Public application URLs
FABRIC_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Optional unified listener overrides (defaults shown)
FABRIC_HOST=0.0.0.0
PORT=3000

# Auth.js — create separate applications and secrets per environment
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me
AUTH_GITHUB_ID=replace-me
AUTH_GITHUB_SECRET=replace-me

# Neon — pooled runtime URL and direct migration URL
DATABASE_URL=postgresql://fabric_web:replace-me@example-pooler.neon.tech/fabric?sslmode=require
DATABASE_URL_DIRECT=postgresql://fabric_migrator:replace-me@example.neon.tech/fabric?sslmode=require

# Server-only workspace rollout for new organization and private-media features.
# When omitted, local/preview/staging default to all and production defaults to off.
FABRIC_WORKSPACE_ROLLOUT_MODE=
FABRIC_WORKSPACE_CANARY_IDS=
# Production examples (never expose either value through NEXT_PUBLIC_*):
# FABRIC_WORKSPACE_ROLLOUT_MODE=off
# FABRIC_WORKSPACE_ROLLOUT_MODE=canary
# FABRIC_WORKSPACE_CANARY_IDS=11111111-1111-4111-8111-111111111111
# FABRIC_WORKSPACE_ROLLOUT_MODE=all

# Private Cloudflare R2 media (Vercel/server-only S3 credentials; never use NEXT_PUBLIC_*)
# The S3 endpoint is derived from the account ID. Keep both configured buckets
# private, disable r2.dev/custom-domain access, and apply the runbook's exact-origin
# browser PUT CORS policy to each distinct bucket.
FABRIC_R2_ACCOUNT_ID=replace-with-your-32-hex-account-id
FABRIC_R2_ACCESS_KEY_ID=replace-with-a-least-privilege-r2-access-key
FABRIC_R2_SECRET_ACCESS_KEY=replace-with-the-matching-r2-secret-key
# Fabric currently uses the same verified private bucket for both logical stores.
# Separate buckets remain supported when their policies and credentials are provisioned.
FABRIC_R2_BOARD_ASSET_BUCKET=fabric
FABRIC_R2_AVATAR_BUCKET=fabric
# Accepted range is 60-900 seconds; keep production grants short-lived.
FABRIC_R2_PRESIGN_TTL_SECONDS=300
# Bearer credential for a scheduler that calls the same-origin cleanup/outbox endpoint.
MEDIA_CLEANUP_SECRET=replace-with-a-distinct-32-character-secret

# Private readiness probe credential (32+ random characters; never expose to browsers)
HEALTHCHECK_SECRET=replace-with-a-distinct-32-character-secret

# Local/custom Node realtime database (Cloudflare Durable Objects do not use this URL)
REALTIME_DATABASE_URL=postgresql://fabric_realtime:replace-me@example-pooler.neon.tech/fabric?sslmode=require
# Shared by the Vercel ticket issuer and the Cloudflare Worker secret store
REALTIME_TICKET_SIGNING_KEY=replace-with-a-dedicated-32-character-secret
# Local/custom Node redemption only; the Cloudflare Worker stores JTI redemption in its room
REALTIME_TICKET_REDEMPTION_KEY=replace-with-a-different-32-character-secret
REALTIME_ALLOWED_ORIGINS=http://localhost:3000
REALTIME_ISSUER=fabric-web
REALTIME_AUDIENCE=fabric-realtime
# Purpose-separated access revocation path. The dispatch secret is Vercel-only and
# protects the scheduled app route; the coordinator secret is shared only by the
# app and realtime Worker for server-to-server delivery.
REALTIME_REVOCATION_ENDPOINT=http://localhost:8787/internal/revocations
REALTIME_REVOCATION_DISPATCH_SECRET=replace-with-a-dedicated-32-character-secret
REALTIME_COORDINATOR_SECRET=replace-with-a-different-32-character-secret
NEXT_PUBLIC_REALTIME_URL=ws://localhost:3000/realtime
# Production Cloudflare Worker example:
# NEXT_PUBLIC_REALTIME_URL=wss://fabric-realtime.<your-workers-subdomain>.workers.dev/realtime

# OpenAI-compatible streaming provider — inject only into server/worker environments
AI_PROVIDER=openai-compatible
AI_RUNS_ENABLED=true
# Vercel enables bounded on-demand dispatch automatically; set this only on another serverless host
# AI_SERVERLESS_DISPATCH_ENABLED=true
AI_BASE_URL=https://ap-south-2.awsbedrock.co/v1
AI_API_KEY=replace-with-server-only-api-key
# Optional managed rotation/failover pool; when set, this replaces AI_API_KEY.
# AI_API_KEYS=replace-with-primary-key,replace-with-rotation-key
AI_MODEL=gcli/grok-4.5-medium
AI_STREAM_ONLY=true

# Dedicated AI worker — never reuse DATABASE_URL or REALTIME_DATABASE_URL
WORKER_DATABASE_URL=postgresql://fabric_worker:replace-me@example-pooler.neon.tech/fabric?sslmode=require
AI_WORKER_POLL_MS=500
AI_EVENT_RETENTION_DAYS=14
AI_RUN_RETENTION_DAYS=30
AI_CLEANUP_INTERVAL_MS=3600000
