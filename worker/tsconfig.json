{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "incremental": false,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../db/schema/**/*.ts",
    "../lib/ai/**/*.ts"
  ],
  "exclude": ["../node_modules"]
}
