{
  "name": "fabric",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file=.env --env-file=.env.local --env-file=.env.worker.local server.ts",
    "build": "next build && esbuild server.ts --bundle --platform=node --format=esm --target=node22 --packages=external --sourcemap --outfile=dist/server.mjs",
    "start": "node dist/server.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate",
    "realtime:typecheck": "tsc -p realtime/tsconfig.json",
    "realtime:worker:typecheck": "tsc -p cloudflare/realtime/tsconfig.test.json",
    "realtime:worker:test": "vitest run --config cloudflare/realtime/vitest.config.mts",
    "realtime:worker:types": "wrangler types cloudflare/realtime/worker-configuration.d.ts --check --config wrangler.toml",
    "ai-worker:typecheck": "tsc -p worker/tsconfig.json",
    "verify:tldraw": "node scripts/verify-tldraw-invariants.mjs",
    "verify": "npm run verify:tldraw && npm run test && npm run typecheck && npm run realtime:typecheck && npm run realtime:worker:typecheck && npm run realtime:worker:test && npm run ai-worker:typecheck && npm run lint && npm run build",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@aws-sdk/client-s3": "3.1087.0",
    "@aws-sdk/s3-request-presigner": "3.1087.0",
    "@fontsource-variable/eb-garamond": "^5.2.7",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/host-grotesk": "^5.2.8",
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@google/genai": "2.11.0",
    "@heroicons/react": "^2.2.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.42.2",
    "jose": "6.2.3",
    "lenis": "1.3.25",
    "lib0": "0.2.117",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.7.0",
    "reicon-react": "1.1.3",
    "server-only": "0.0.1",
    "tailwind-merge": "^3.6.0",
    "tldraw": "4.2.0",
    "ws": "8.21.0",
    "y-indexeddb": "9.0.12",
    "y-protocols": "1.0.7",
    "yjs": "13.6.31",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "8.18.1",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.28.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "happy-dom": "^20.10.6",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.2",
    "tsx": "4.23.1",
    "typescript": "^5.9.3",
    "vitest": "4.1.10",
    "wrangler": "^4.111.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  }
}
